<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body class="bg-zinc-900 text-white p-10">
    <form action="" class="flex flex-col items-center gap-5">
        <input type="text" placeholder="Name" class="border-2 border-zinc-800 rounded-2xl bg-transparent outline-none py-2 px-2"
            name="name">
        <input type="text" placeholder="Email" class="border-2 border-zinc-800  rounded-2xl bg-transparent outline-none py-2 px-2"
            name="email">
        <input type="text" placeholder="IMG url" class="border-2 border-zinc-800  rounded-2xl bg-transparent outline-none py-2 px-2"
            name="img url">
        <input type="submit" class="btn rounded-2xl bg-blue-500 hover:bg-blue-700 text-amber-50 outline-none py-2 px-2"
            value="submit">
    </form>
</body>

</html>